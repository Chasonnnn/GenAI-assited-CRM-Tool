{
  "name": "my-v0-project",
  "version": "0.3.0",
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "gen:stages": "if [ -x ../api/.venv/bin/python ]; then cd ../api && .venv/bin/python ../../scripts/gen_stage_map.py; else echo 'Skipping stage generation (apps/api/.venv missing)'; fi",
    "gen:surrogate-contracts": "if [ -x ../api/.venv/bin/python ]; then cd ../api && .venv/bin/python ../../scripts/gen_surrogate_contracts.py; else echo 'Skipping surrogate contract generation (apps/api/.venv missing)'; fi",
    "prebuild": "pnpm run gen:stages && pnpm run gen:surrogate-contracts",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "NODE_OPTIONS=--localstorage-file=/tmp/vitest-localstorage vitest run",
    "test:watch": "NODE_OPTIONS=--localstorage-file=/tmp/vitest-localstorage vitest",
    "test:integration": "NODE_OPTIONS=--localstorage-file=/tmp/vitest-localstorage vitest run --config vitest.integration.config.ts",
    "test:all": "pnpm run test && pnpm run test:integration",
    "check": "pnpm run typecheck && pnpm run lint && pnpm run test",
    "analyze": "next experimental-analyze"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@fullcalendar/core": "^6.1.21",
    "@fullcalendar/daygrid": "^6.1.21",
    "@fullcalendar/interaction": "^6.1.21",
    "@fullcalendar/react": "^6.1.21",
    "@fullcalendar/timegrid": "^6.1.21",
    "@hookform/resolvers": "^5.4.0",
    "@tanstack/react-query": "^5.101.2",
    "@tiptap/extension-image": "^3.27.1",
    "@tiptap/extension-link": "^3.27.1",
    "@tiptap/extension-placeholder": "^3.27.1",
    "@tiptap/extension-text-align": "^3.27.1",
    "@tiptap/react": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "@types/d3-scale": "^4.0.9",
    "@types/react-simple-maps": "^3.0.6",
    "autoprefixer": "^10.5.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "d3-scale": "^4.0.2",
    "date-fns": "4.4.0",
    "dompurify": "^3.4.12",
    "embla-carousel-react": "8.6.0",
    "emoji-picker-react": "^4.19.1",
    "lucide-react": "^1.22.0",
    "markdown-it": "14.2.0",
    "next": "16.2.11",
    "next-themes": "^0.4.6",
    "qrcode.react": "^4.2.0",
    "react": "19.2.7",
    "react-day-picker": "10.0.1",
    "react-dom": "19.2.7",
    "react-dropzone": "^15.0.0",
    "react-hook-form": "^7.80.0",
    "react-simple-maps": "^3.0.0",
    "recharts": "^3.9.0",
    "tailwind-merge": "^3.6.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@next/bundle-analyzer": "16.2.9",
    "@tailwindcss/postcss": "^4.3.2",
    "@tanstack/react-query-devtools": "^5.101.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/markdown-it": "14.1.2",
    "@types/node": "^26.0.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "postcss": "8.5.16",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "1.4.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "8.1.0",
    "vitest": "^4.1.9"
  }
}
